{
  "permissions": {
    "allow": [
      "Bash(make)",
      "Bash(make *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/credentials*)",
      "Read(**/*secret*)"
    ]
  }
}
